<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academic Calendar | Hybrid School ERP</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
/* STYLE OMITTED FOR TOKEN REDUCTION */
</style>

</head>

<body x-data="calendarApp()" class="flex h-screen overflow-hidden text-slate-800">

    <!-- SIDEBAR OMITTED FOR TOKEN REDUCTION -->
<!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col h-full overflow-hidden relative bg-white">
        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 border-b border-gray-200 flex-shrink-0 bg-white z-10">
            <div class="flex items-center gap-4">
                <button @click="sidebarOpen = !sidebarOpen" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-bars"></i></button>
                <div class="flex items-center gap-2">
                    <h1 class="text-lg font-bold text-slate-800">Academic Calendar</h1>
                    <select class="ml-2 bg-gray-50 border border-gray-200 text-sm font-medium rounded-md px-2 py-1 outline-none text-gray-600">
                        <option>2025-2026</option>
                        <option>2024-2025</option>
                    </select>
                </div>
            </div>

            <!-- Header Controls -->
            <div class="flex items-center gap-4">
                <button @click="goToday()" class="px-4 py-1.5 text-sm font-medium border border-gray-200 rounded-full hover:bg-gray-50 text-gray-700">Today</button>
                
                <div class="flex items-center gap-4 px-2">
                    <button @click="prevMonth()" class="text-gray-400 hover:text-gray-700 w-6 h-6 flex items-center justify-center rounded-full hover:bg-gray-100"><i class="fa-solid fa-chevron-left text-xs"></i></button>
                    <span class="text-base font-bold text-gray-800 w-36 text-center select-none" x-text="getMonthYearString()"></span>
                    <button @click="nextMonth()" class="text-gray-400 hover:text-gray-700 w-6 h-6 flex items-center justify-center rounded-full hover:bg-gray-100"><i class="fa-solid fa-chevron-right text-xs"></i></button>
                </div>

                <div class="flex bg-gray-100 rounded-lg p-1 text-sm font-medium">
                    <button @click="viewMode = 'month'" :class="viewMode === 'month' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1 rounded-md transition-all">Month</button>
                    <button @click="viewMode = 'week'" :class="viewMode === 'week' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1 rounded-md transition-all">Week</button>
                    <button @click="viewMode = 'year'" :class="viewMode === 'year' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1 rounded-md transition-all">Year</button>
                </div>
            </div>

            <!-- Add Buttons -->
            <div class="flex gap-2">
                <button @click="openModal('holiday')" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-red-600 border border-red-200 bg-red-50 rounded-full hover:bg-red-100 transition-colors"><i class="fa-solid fa-plus text-[10px]"></i> Holiday</button>
                <button @click="openModal('event')" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-gray-600 border border-gray-200 bg-gray-50 rounded-full hover:bg-gray-100 transition-colors"><i class="fa-solid fa-plus text-[10px]"></i> Event</button>
                <button @click="openModal('exam')" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-white bg-blue-600 rounded-full hover:bg-blue-700 shadow-sm transition-colors"><i class="fa-solid fa-plus text-[10px]"></i> Exam Period</button>
            </div>
        </header>

        <!-- DASHBOARD AREA -->
        <div class="flex flex-1 overflow-hidden bg-[#f8fafc]">
            
            <!-- LEFT SETTINGS SIDEBAR -->
            <div class="w-64 max-w-[16rem] bg-white border-r border-gray-200 overflow-y-auto p-4 flex flex-col gap-4 flex-shrink-0">
                
                <!-- Session Panel -->
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Session</span>
                        <button class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-pen text-xs"></i></button>
                    </div>
                    <div class="text-base font-bold text-gray-800 mb-4">2025-2026</div>
                    <div class="grid grid-cols-2 gap-2 text-xs mb-4">
                        <div>
                            <div class="text-gray-400 uppercase font-semibold text-[9px] tracking-wider mb-1">Start</div>
                            <div class="font-medium text-gray-700">Apr 1, 2025</div>
                        </div>
                        <div>
                            <div class="text-gray-400 uppercase font-semibold text-[9px] tracking-wider mb-1">End</div>
                            <div class="font-medium text-gray-700">Mar 31, 2026</div>
                        </div>
                    </div>
                    <div class="flex gap-2 text-center text-xs">
                        <div class="flex-1 bg-emerald-50 text-emerald-700 rounded-lg py-2 border border-emerald-100">
                            <div class="text-lg font-bold">306</div>
                            <div class="text-[9px] uppercase tracking-wider mt-0.5 opacity-80 font-semibold">Working Days</div>
                        </div>
                        <div class="flex-1 bg-red-50 text-red-700 rounded-lg py-2 border border-red-100">
                            <div class="text-lg font-bold">7</div>
                            <div class="text-[9px] uppercase tracking-wider mt-0.5 opacity-80 font-semibold">Holidays</div>
                        </div>
                    </div>
                </div>

                <!-- Working Days Panel -->
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                    <div class="flex items-center gap-2 mb-4 text-[10px] font-bold text-gray-400 uppercase tracking-wider">
                        <i class="fa-regular fa-calendar-check"></i> Working Days
                    </div>
                    <div class="space-y-3">
                        <template x-for="day in ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']">
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-gray-600 font-medium" x-text="day"></span>
                                <div class="relative inline-block w-8 mr-2 align-middle select-none transition duration-200 ease-in">
                                    <input type="checkbox" :checked="day !== 'Sunday'" class="toggle-checkbox absolute block w-4 h-4 rounded-full bg-white border-4 appearance-none cursor-pointer top-0 bottom-0 m-auto right-[16px]" style="border-color: #cbd5e1;" />
                                    <label class="toggle-label block overflow-hidden h-4 rounded-full bg-gray-200 cursor-pointer"></label>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- Period Timing Panel -->
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-2 text-[10px] font-bold text-gray-400 uppercase tracking-wider">
                            <i class="fa-regular fa-clock"></i> Period Timing
                        </div>
                        <button class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-pen text-xs"></i></button>
                    </div>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between"><span class="text-gray-500 font-medium">School Start</span> <span class="font-bold text-gray-800">8:00 AM</span></div>
                        <div class="flex justify-between"><span class="text-gray-500 font-medium">Assembly</span> <span class="font-bold text-gray-800">15 mins</span></div>
                        <div class="flex justify-between"><span class="text-gray-500 font-medium">Period</span> <span class="font-bold text-gray-800">45 mins</span></div>
                        <div class="flex justify-between"><span class="text-gray-500 font-medium">Break</span> <span class="font-bold text-gray-800">20 mins</span></div>
                        <div class="flex justify-between"><span class="text-gray-500 font-medium">Periods/Day</span> <span class="font-bold text-gray-800">8</span></div>
                    </div>
                </div>

                <!-- Legend Panel -->
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                    <div class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-3">Legend</div>
                    <div class="space-y-2.5 text-xs font-medium text-gray-600">
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full border-2 border-red-400 box-border"></div> Holiday</div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full border-2 border-amber-400 box-border"></div> Exam Period</div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full border-2 border-purple-400 box-border"></div> Event</div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full border-2 border-gray-400 box-border"></div> Break Period</div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full border-2 border-blue-400 box-border"></div> Special Working</div>
                    </div>
                </div>

            </div>

            <!-- CALENDAR GRID BODY -->
            <div class="flex-1 p-6 flex flex-col h-full bg-[#f8fafc] overflow-hidden">
                <div class="flex-1 flex flex-col calendar-grid shadow-sm">
                    <!-- Weekday Headers -->
                    <div class="calendar-header-cell">Sun</div>
                    <div class="calendar-header-cell">Mon</div>
                    <div class="calendar-header-cell">Tue</div>
                    <div class="calendar-header-cell">Wed</div>
                    <div class="calendar-header-cell">Thu</div>
                    <div class="calendar-header-cell">Fri</div>
                    <div class="calendar-header-cell">Sat</div>

                    <!-- Calendar Cells -->
                    <template x-for="dateObj in calendarDays" :key="dateObj.dateString">
                        <div 
                            class="calendar-day-cell group" 
                            :class="{
                                'is-other-month': !dateObj.isCurrentMonth,
                                'is-today': dateObj.isToday
                            }"
                            @click="selectedDate = dateObj.dateString; showModal = true"
                        >
                            <span class="day-number" x-text="dateObj.day"></span>

                            <!-- Events rendering logic -->
                            <div class="flex flex-col gap-1 w-full flex-1">
                                <template x-for="event in getEventsForDate(dateObj.dateString)" :key="event.id">
                                    <div class="event-bar" :class="getEventColorClass(event.type)" x-text="event.title" @click.stop=""></div>
                                </template>
                            </div>

                            <!-- Add Button Overlay -->
                            <button @click.stop="openModal('event', dateObj.dateString)" class="add-btn absolute bottom-2 right-2 w-6 h-6 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-colors shadow-sm">
                                <i class="fa-solid fa-plus text-[10px]"></i>
                            </button>
                        </div>
                    </template>
                </div>
            </div>

            <!-- UPCOMING EVENTS RIGHT SIDEBAR -->
            <div class="w-72 bg-white border-l border-gray-200 overflow-y-auto p-4 flex flex-col gap-6 flex-shrink-0 shadow-[inset_1px_0_0_rgba(0,0,0,0.05)]">
                <div>
                    <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">Upcoming Events & Exams</h3>
                    <div class="space-y-3">
                        <template x-for="evt in getUpcomingEvents()" :key="evt.id">
                            <div class="flex items-start gap-3 p-3 rounded-xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50/50 transition-all cursor-pointer shadow-sm">
                                <div class="flex-col items-center flex bg-gray-50 rounded-lg p-2 min-w-[50px]">
                                    <span class="text-[9px] font-bold uppercase text-slate-500 w-full text-center" x-text="formatShortMonth(evt.date)"></span>
                                    <span class="text-lg font-bold text-slate-800 leading-none mt-1" x-text="formatDay(evt.date)"></span>
                                </div>
                                <div class="flex-1 py-1">
                                    <h4 class="text-sm font-semibold text-slate-800 leading-tight" x-text="evt.title"></h4>
                                    <div class="flex items-center gap-1.5 mt-2">
                                        <div class="w-2 h-2 rounded-full" :class="getDotColorClass(evt.type)"></div>
                                        <span class="text-[10px] font-medium text-slate-500 uppercase tracking-wider" x-text="formatEventType(evt.type)"></span>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="getUpcomingEvents().length === 0" class="text-sm text-gray-500 text-center py-8">
                            No upcoming events found.
                        </div>
                    </div>
                </div>

                <!-- Monthly summary quick view -->
                <div class="mt-auto">
                    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-100 relative overflow-hidden">
                        <div class="absolute -right-4 -bottom-4 opacity-10">
                            <i class="fa-solid fa-calendar-days text-6xl text-blue-600"></i>
                        </div>
                        <h4 class="text-xs font-bold text-blue-800 uppercase mb-3 relative z-10">This Month</h4>
                        <div class="space-y-2 text-sm relative z-10">
                            <div class="flex justify-between items-center"><span class="text-blue-700 font-medium text-xs">Total Events</span> <span class="font-bold text-blue-900 bg-white px-2 py-0.5 rounded-md shadow-sm" x-text="getCurrentMonthEventCount()"></span></div>
                            <div class="flex justify-between items-center"><span class="text-blue-700 font-medium text-xs">Exams/Tests</span> <span class="font-bold text-blue-900 bg-white px-2 py-0.5 rounded-md shadow-sm" x-text="getCurrentMonthExamCount()"></span></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ADD EVENT MODAL -->
        <div x-show="showModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm transition-opacity">
            <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all" @click.away="showModal=false">
                <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-gray-50/80">
                    <h3 class="font-bold text-slate-800 text-lg">Add to Calendar</h3>
                    <button @click="showModal=false" class="w-8 h-8 rounded-full bg-white text-slate-400 hover:text-slate-600 hover:bg-gray-200 flex items-center justify-center transition-colors shadow-sm"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="p-6 space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Date</label>
                        <input type="date" x-model="newEvent.date" class="w-full border border-slate-200 rounded-xl p-3 text-sm text-gray-700 font-medium focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all shadow-sm">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Title</label>
                        <input type="text" x-model="newEvent.title" class="w-full border border-slate-200 rounded-xl p-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition-all shadow-sm" placeholder="E.g., Final Physics Exam">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Type</label>
                        <div class="grid grid-cols-3 gap-3">
                            <button @click="newEvent.type = 'event'" :class="newEvent.type === 'event' ? 'bg-purple-50 border-purple-500 text-purple-700 ring-2 ring-purple-200' : 'border-slate-200 text-gray-600 hover:bg-gray-50'" class="border rounded-xl py-3 text-sm font-semibold transition-all shadow-sm cursor-pointer">Event</button>
                            <button @click="newEvent.type = 'holiday'" :class="newEvent.type === 'holiday' ? 'bg-red-50 border-red-500 text-red-700 ring-2 ring-red-200' : 'border-slate-200 text-gray-600 hover:bg-gray-50'" class="border rounded-xl py-3 text-sm font-semibold transition-all shadow-sm cursor-pointer">Holiday</button>
                            <button @click="newEvent.type = 'exam'" :class="newEvent.type === 'exam' ? 'bg-amber-50 border-amber-500 text-amber-700 ring-2 ring-amber-200' : 'border-slate-200 text-gray-600 hover:bg-gray-50'" class="border rounded-xl py-3 text-sm font-semibold transition-all shadow-sm cursor-pointer">Exam</button>
                        </div>
                    </div>
                </div>
                <div class="px-6 py-4 bg-gray-50 border-t border-slate-100 flex justify-end gap-3 rounded-b-2xl">
                    <button @click="showModal=false" class="px-5 py-2.5 text-sm text-slate-600 font-bold hover:bg-gray-200 rounded-xl transition-colors">Cancel</button>
                    <button @click="saveEvent()" class="px-5 py-2.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold shadow-md shadow-blue-200 transition-all transform active:scale-95 flex items-center gap-2">
                        <i class="fa-solid fa-check"></i> Save Entry
                    </button>
                </div>
            </div>
        </div>

    </main>

    <script>\n/* SCRIPT OMITTED FOR TOKEN REDUCTION */\n</script>\n</body>\n</html>\n